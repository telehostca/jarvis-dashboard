# Jarvis AGENT backend URL (NOT the dashboard URL!)
# This is the API server that handles auth, tenants, apps, etc.
# In production: https://agent.telehost.net
# Locally: http://localhost:3000
JARVIS_API_URL=https://agent.telehost.net

# Anthropic API key (for demo chat on landing page)
ANTHROPIC_API_KEY=sk-ant-...

# Admin key (required only for admin operations from dashboard)
# JARVIS_ADMIN_KEY=
