diff --git a/src/manager.test.ts b/src/manager.test.ts
index 40ad90a..a03b438 100644
--- a/src/manager.test.ts
+++ b/src/manager.test.ts
@@ -89,4 +89,79 @@ describe("JarvisManager", () => {
       error: expect.stringContaining("timed out"),
     });
   });
+
+  it("status is 'down' when all metrics fail", async () => {
+    const m = new JarvisManager({
+      metrics: {
+        a: async () => {
+          throw new Error("boom 1");
+        },
+        b: async () => {
+          throw new Error("boom 2");
+        },
+      },
+    });
+
+    const payload = await m.buildPayload();
+
+    expect(payload.status).toBe("down");
+  });
+
+  it("status is not 'down' when only some metrics fail", async () => {
+    const m = new JarvisManager({
+      metrics: {
+        ok: async () => 42,
+        fails: async () => {
+          throw new Error("partial");
+        },
+      },
+    });
+
+    const payload = await m.buildPayload();
+
+    expect(payload.status).toBe("healthy");
+  });
+
+  it("status is 'healthy' when no metrics defined", async () => {
+    const m = new JarvisManager();
+
+    const payload = await m.buildPayload();
+
+    expect(payload.status).toBe("healthy");
+  });
+
+  it("'down' takes priority over critical alert", async () => {
+    const m = new JarvisManager({
+      metrics: {
+        a: async () => {
+          throw new Error("all dead");
+        },
+      },
+      alerts: {
+        crit: async () => ({ severity: "critical", message: "fire" }),
+      },
+    });
+
+    const payload = await m.buildPayload();
+
+    expect(payload.status).toBe("down");
+  });
+
+  it("alerts preserve declaration order even when run in parallel", async () => {
+    const m = new JarvisManager({
+      alerts: {
+        slow: async () => {
+          await new Promise((r) => setTimeout(r, 50));
+          return { severity: "warning" as const, message: "slow first" };
+        },
+        fast: async () => ({ severity: "info" as const, message: "fast second" }),
+      },
+    });
+
+    const payload = await m.buildPayload();
+
+    expect(payload.alerts).toHaveLength(2);
+    expect(payload.alerts[0]?.message).toBe("slow first");
+    expect(payload.alerts[1]?.message).toBe("fast second");
+  });
 });
